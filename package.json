{
  "name": "stride-x-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "dev": "pnpm --dir apps/api dev",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:all": "pnpm --parallel --filter @stride-x/api --filter @aevra/web dev",
    "build": "pnpm --dir apps/api build && pnpm --dir apps/web build",
    "build:api": "pnpm --dir apps/api build",
    "build:web": "pnpm --dir apps/web build",
    "typecheck": "pnpm --dir apps/api typecheck && pnpm --dir apps/web typecheck",
    "test": "pnpm typecheck"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@types/node": "^22.15.3",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
